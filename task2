/* Inter-process communication bus definition [cite: 37, 38, 39, 40] */
messagebus_t bus;
MUTEX_DECL(bus_lock);
CONDVAR_DECL(bus_condvar);

/* Helper function to find the maximum of two values */
static inline int imax(int a, int b){ return (a>b)?a:b; }

int main(void)
{
    /* Mandatory Initialisations [cite: 8, 12, 13, 14] */
    halInit();
    chSysInit();
    mpu_init();

    /* Proximity Sensor Initialisation [cite: 41, 42, 43, 45, 46] */
    messagebus_init(&bus, &bus_lock, &bus_condvar);
    proximity_start(); 
    calibrate_ir();

    /* LED Initialisation [cite: 16, 17, 23, 24] */
    clear_leds();
    spi_comm_start();

    /* Motors Initialisation [cite: 149, 150] */
    motors_init();

    /* --- Thresholds for Task 2 (Chasing) --- */
    const int CHASE_TH     = 200;   // Minimum signal to detect "prey"
    const int COLLISION_TH = 1500;  // Signal strength to stop before hitting object
    const int MAX_SPEED    = 500;   // Speed within allowed [-1000, 1000] range [cite: 148]

    while (1)
    {
        /* Get calibrated readings from front-right (0) and front-left (7) [cite: 49, 50] */
        int rf = get_calibrated_prox(0); 
        int lf = get_calibrated_prox(7); 
        int front = imax(rf, lf);

        /* 1) COLLISION AVOIDANCE: Stop if object is too close */
        if (front > COLLISION_TH) {
            left_motor_set_speed(0); [cite: 152]
            right_motor_set_speed(0); [cite: 153]
            
            // Visual feedback: Turn on Front LED when stopped [cite: 32, 33]
            set_front_led(1); 
        }
        
        /* 2) CHASE LOGIC: Move toward the detected object */
        else if (front > CHASE_TH) {
            set_front_led(0); // Object is at a safe distance [cite: 33]
            
            if (lf > rf + 50) {
                // Object is more to the left -> Turn Left to chase
                left_motor_set_speed(MAX_SPEED * 0.2); 
                right_motor_set_speed(MAX_SPEED); [cite: 153]
            } 
            else if (rf > lf + 50) {
                // Object is more to the right -> Turn Right to chase
                left_motor_set_speed(MAX_SPEED); [cite: 152]
                right_motor_set_speed(MAX_SPEED * 0.2); 
            } 
            else {
                // Object is centered -> Go straight toward it
                left_motor_set_speed(MAX_SPEED); [cite: 152]
                right_motor_set_speed(MAX_SPEED); [cite: 153]
            }
        }
        
        /* 3) SEARCH LOGIC: If nothing is seen, spin in place to find the object */
        else {
            set_front_led(0); [cite: 33]
            left_motor_set_speed(300); [cite: 152]
            right_motor_set_speed(-300); [cite: 153]
        }

        /* Continuous LED status [cite: 29, 31] */
        set_rgb_led(LED2, 0, 5, 0); // Green LEDs while active
        set_body_led(1); 

        /* Loop delay to allow system threads to process [cite: 201, 202] */
        chThdSleepMilliseconds(50); 
    }
}

